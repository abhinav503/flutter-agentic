rules_version = '2';

// Multi-tenant rules for the FlutterAgenticEcommerce platform.
// Schema: docs/explanation/superapp-ecommerce-plan.md
//
// Store-write authority is ownerUid-based for now. A `storeIds` custom
// claim exists (stamped by the admin console's POST /api/stores; trusted by
// the REST API's requireStoreOwner) but is not yet read here — a `role:
// storeAdmin` claim ships in a later milestone; tighten to
// `request.auth.token.role == 'storeAdmin'` once it exists.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerUid == request.auth.uid;
    }

    // Shopper profile — created on gravia sign-up.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /carts/{storeId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Store-owner record — created on admin-console sign-up with an empty
    // storeIds list; from then on the doc is server-maintained (the admin
    // console's POST /api/stores appends storeIds via the Admin SDK and
    // stamps the matching `storeIds` custom claim). Client updates are
    // forbidden so a signed-in admin can't grant itself another store —
    // the claim, not this doc, is what the REST API's requireStoreOwner
    // trusts. Clients only read it (dashboard StoreProvider onSnapshot).
    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.storeIds.size() == 0;
      allow update, delete: if false;
    }

    // Store catalog — world-readable for shopper discovery/browsing;
    // creation is server-only (POST /api/stores, Admin SDK bypasses rules)
    // so ownership and the storeIds claim always move together; other
    // writes restricted to the store's own owner.
    match /stores/{storeId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isStoreOwner(storeId);

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isStoreOwner(storeId);
      }

      match /products/{productId} {
        allow read: if true;
        allow write: if isStoreOwner(storeId);
      }
    }

    // Orders — a shopper creates/reads their own; the owning store can read
    // (and later advance status). No client-side price trust beyond create.
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isStoreOwner(resource.data.storeId));
      allow update: if isStoreOwner(resource.data.storeId);
      allow delete: if false;
    }
  }
}
