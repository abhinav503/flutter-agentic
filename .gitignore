# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
# Monorepo: build/coverage artifacts live under each package (apps/*, packages/*),
# so these must match at any depth — not just the repo root.
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/build/
**/coverage/

# Dart pub workspace / Melos
**/pubspec_overrides.yaml
.melos_tool/

# Node / JS (web-terminal console + server) — repo-wide so any JS project is
# covered even without its own .gitignore. Nested .gitignores also apply.
**/node_modules/
**/.next/
**/out/
**/.pnp
**/.pnp.*
**/.vercel
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env — .local overrides at any depth (bare .env is covered below)
**/.env*.local

# fvm — pinned SDK is a local symlink; keep .fvmrc / fvm_config.json, ignore the SDK
.fvm/flutter_sdk
.fvm/versions/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here (any app under apps/*)
**/android/app/debug
**/android/app/profile
**/android/app/release

# Local machine config — never commit
**/android/local.properties
.claude/settings.local.json

# API keys and secrets — local only, never commit
.env
.vscode/launch.json

# Android signing — never commit
**/android/key.properties
*.keystore
*.jks

# Firebase config — never commit to public repo
**/ios/Runner/GoogleService-Info.plist
**/android/app/google-services.json
